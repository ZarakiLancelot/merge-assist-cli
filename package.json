{
  "name": "merge-assist-cli",
  "version": "1.0.0",
  "description": "AI-powered merge conflict resolver using GitHub Copilot CLI",
  "main": "dist/index.js",
  "bin": {
    "merge-assist": "dist/index.js"
  },
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node src/index.js",
    "build": "tsc",
    "start": "npm run build && node dist/index.js",
    "clean": "rm -rf dist",
    "test:detect": "ts-node src/index.ts detect",
    "test:analyze": "ts-node src/index.ts analyze",
    "prebuild": "npm run clean"
  },
  "keywords": [
    "merge-conflicts",
    "git",
    "copilot-cli",
    "ai",
    "cli-tool"
  ],
  "author": "Edwin Einsen Vásquez Velásquez",
  "license": "MIT",
  "description": "AI-powered merge conflict resolver using GitHub Copilot CLI",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "inquirer": "^13.2.1",
    "simple-git": "^3.30.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.0.10",
    "dotenv": "^17.2.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
